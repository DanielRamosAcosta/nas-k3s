{
  "$schema": "./invidious.config.schema.json",
  "db": {
    "dbname": "invidious",
    "user": "invidious",
    "host": "postgres.databases.svc.cluster.local",
    "port": 5432,
    "password": "$DB_PASSWORD"
  },
  "check_tables": true,
  "invidious_companion_key": "$INVIDIOUS_COMPANION_KEY",
  "hmac_key": "$HMAC_KEY",
  "invidious_companion": [
    {
      "private_url": "http://invidious-companion.media.svc.cluster.local:8282/companion"
    }
  ],
  "domain": "invidious.danielramos.me",
  "https_only": true,
  "registration_enabled": false,
  "admins": [
    "dani"
  ],
  "default_user_preferences": {
    "locale": "es",
    "region": "ES",
    "captions": [
      "Spanish",
      "Spanish (Latin America)",
      "English"
    ],
    "autoplay": true,
    "continue": true,
    "save_player_pos": true
  }
}