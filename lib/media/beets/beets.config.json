{
    "$schema": "./beets.config.schema.json",
    "plugins": "musicbrainz fetchart embedart convert scrub replaygain lastgenre chroma web missing",
    "directory": "/music",
    "library": "/data/musiclibrary.blb",
    "art_filename": "albumart",
    "threaded": true,
    "original_date": false,
    "per_disc_numbering": false,
    "convert": {
        "auto": false,
        "ffmpeg": "/usr/bin/ffmpeg",
        "opts": "-ab 320k -ac 2 -ar 48000",
        "max_bitrate": 320,
        "threads": 1
    },
    "paths": {
        "comp": "$albumartist/$albumtype/$album ($year)/$albumartist - $album - $track - $title",
        "singleton": "$albumartist/Single/$album ($year)/$albumartist - $album - $track - $title",
        "albumtype:single": "$albumartist/Single/$album ($year)/$albumartist - $album - $track - $title",
        "default": "$albumartist/Album/$album ($year)/$albumartist - $album - $track - $title"
    },
    "import": {
        "write": true,
        "copy": false,
        "move": false,
        "resume": "ask",
        "incremental": true,
        "quiet_fallback": "skip",
        "timid": true,
        "log": "/data/beet.log"
    },
    "lastgenre": {
        "auto": false,
        "source": "album"
    },
    "embedart": {
        "auto": true
    },
    "fetchart": {
        "auto": true
    },
    "replaygain": {
        "auto": false,
        "command": "mp3gain"
    },
    "scrub": {
        "auto": true
    },
    "replace": {
        "^\\.": "_",
        "[\\x00-\\x1f]": "_",
        "[<>:\"\\?\\*\\|]": "_",
        "[\\xE8-\\xEB]": "e",
        "[\\xEC-\\xEF]": "i",
        "[\\xE2-\\xE6]": "a",
        "[\\xF2-\\xF6]": "o",
        "[\\xF8]": "o",
        "\\.$": "_",
        "\\s+$": ""
    },
    "web": {
        "host": "0.0.0.0",
        "port": 8337
    }
}